{
  "expo": {
    "name": "Ledger",
    "slug": "binance-loan-tracker",
    "owner": "elandref",
    "extra": {
      "eas": {
        "projectId": "507ca16a-ae95-4f54-84f2-fef5180a4f93"
      }
    },
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/images/icon.png",
    "scheme": "binance-loan-tracker",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#06090C"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ubuntu.life.ledger",
      "appleTeamId": "42G8TCTL98",
      "buildNumber": "1",
      "usesAppleSignIn": true,
      "entitlements": {
        "com.apple.security.application-groups": ["group.com.ledger.shared"]
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSFaceIDUsageDescription": "Unlock Ledger and your stored Binance API keys with Face ID.",
        "NSCameraUsageDescription": "Scan a QR code from Binance to import an API key without typing it.",
        "UIBackgroundModes": ["fetch", "processing"],
        "NSSupportsLiveActivities": true,
        "BGTaskSchedulerPermittedIdentifiers": ["com.ubuntu.life.ledger.refresh"]
      }
    },
    "android": {},
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "color": "#00F0FF"
        }
      ],
      "expo-secure-store",
      "expo-apple-authentication",
      [
        "expo-camera",
        {
          "cameraPermission": "Scan a QR code from Binance to import an API key without typing it.",
          "recordAudioAndroid": false
        }
      ],
      "expo-background-fetch",
      "expo-task-manager",
      "@bacons/apple-targets",
      "./plugins/withSyncedExtensionBuildNumbers"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
